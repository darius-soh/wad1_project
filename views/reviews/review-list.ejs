<%- include("../common/header", { title: title, user: user }) %>

<!-- Page heading -->
<table width="100%">
  <tr>
    <td>
      <h2>All Reviews</h2>
        <form action="/reviews/add" method="GET">
          <button type="submit">Add a review</button>
        </form>
    </td>
  </tr>
</table>
<hr>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Message when there are no reviews -->
<% if (!reviews || reviews.length === 0) { %>
  <p>No reviews found.</p>
<% } %>

<!-- Reviews table -->
<!-- Each review is shown in its own detail table -->
<% if (reviews && reviews.length > 0) { %>
  <% for (const review of reviews) { %>
    <table width="50%" border="1">
      <tr>
        <th style="width: 140px; text-align: left;">Title</th>
        <td><%= review.title %></td>
      </tr>
      <tr>
        <th style="width: 140px; text-align: left;">Song</th>
        <td><%= review.songTitle %></td>
      </tr>
      <tr>
        <th style="width: 140px; text-align: left;">Playlist</th>
        <td><%= review.playlistName %></td>
      </tr>
      <tr>
        <th style="width: 140px; text-align: left;">Rating</th>
        <td><%= review.rating %>/5</td>
      </tr>
      <tr>
        <th style="width: 140px; text-align: left;">Comment</th>
        <td><%= review.comment %></td>
      </tr>
      <tr>
        <th style="width: 140px; text-align: left;">Action</th>
        <td>
          <form action="/reviews/edit" method="GET" style="display: inline-block;">
            <input type="hidden" name="reviewId" value="<%= review._id %>">
            <button type="submit" style="width: 55px;">Edit</button>
          </form>
          <form action="/reviews/delete" method="POST" style="display: inline-block;">
            <input type="hidden" name="reviewId" value="<%= review._id %>">
            <button type="submit" onclick="return confirm('Are you sure you want to delete this?');">Delete</button>
          </form>
        </td>
      </tr>
    </table>
    <br>
  <% } %>
<% } %>

</main>
</body>
</html>
