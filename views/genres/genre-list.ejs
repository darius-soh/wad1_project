<%- include("../common/header", { title: title, user: user }) %>

<!-- Page heading -->
<table width="100%">
  <tr>
    <td>
      <h2>All Genres</h2>
        <form action="/genres/add" method="GET">
          <button type="submit">Add a genre</button>
        </form>
    </td>
  </tr>
</table>
<hr>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Message when there are no genres -->
<% if (!genres || genres.length === 0) { %>
  <p>No genres found.</p>
<% } %>

<!-- Genres table -->
<!-- Each genre is displayed as its own small table -->
<% if (genres && genres.length > 0) { %>
  <% for (const genre of genres) { %>
    <table width="50%" border="1">
      <tr>
        <td width="20%"><strong>Name:</strong></td>
        <td><%= genre.name %></td>
      </tr>
      <tr>
        <td><strong>Description:</strong></td>
        <td><%= genre.description %></td>
      </tr>
      <tr>
        <td><strong>Created:</strong></td>
        <td><%= genre.createdAt.toLocaleString() %></td>
      </tr>
      <tr>
        <td><strong>Action:</strong></td>
        <td>
          <form action="/genres/edit" method="GET" style="display: inline-block;">
            <input type="hidden" name="genreId" value="<%= genre._id %>">
            <button type="submit" style="width: 55px;">Edit</button>
          </form>
          <form action="/genres/delete" method="POST" style="display: inline-block;">
            <input type="hidden" name="genreId" value="<%= genre._id %>">
            <button type="submit" onclick="return confirm('Are you sure you want to delete this?');">Delete</button>
          </form>
        </td>
      </tr>
    </table>
    <br>
    <hr>
    <br>
  <% } %>
<% } %>

</main>
</body>
</html>
