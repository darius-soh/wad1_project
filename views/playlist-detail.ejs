<%- include("common/header", { title: title }) %>

<!-- Error message -->
<% if (error) { %>
  <p class="error"><%= error %></p>
<% } %>

<!-- Back link if playlist is missing -->
<% if (!playlist) { %>
  <p><a href="/playlists">Back to playlists</a></p>
<% } %>

<!-- Playlist details -->
<% if (playlist) { %>
  <h2><%= playlist.name %></h2>
  <p><strong>Description:</strong> <%= playlist.description %></p>
  <p><strong>Genre:</strong> <%= playlist.genre %></p>
  <p><strong>Created:</strong> <%= playlist.createdAt.toLocaleString() %></p>

  <p><a href="/playlists/songs/add?id=<%= playlist._id %>">Add Song</a></p>

  <form action="/playlists/delete" method="POST">
    <input type="hidden" name="playlistId" value="<%= playlist._id %>">
    <button type="submit">Delete Playlist</button>
  </form>

  <h3>Songs</h3>

  <!-- Message when there are no songs -->
  <% if (!songs.length) { %>
    <p>No songs added yet.</p>
  <% } %>

  <!-- Song cards -->
  <% for (const song of songs) { %>
      <h3><%= song.title %></h3>
      <p><strong>Artist:</strong> <%= song.artist %></p>
      <p><strong>Album:</strong> <%= song.album %></p>

      <% if (song.rating) { %>
        <p><strong>Rating:</strong> <%= song.rating %>/5</p>
      <% } %>

      <% if (song.review) { %>
        <p><strong>Review:</strong> <%= song.review %></p>
      <% } %>

      <!-- toLocaleString has been explained earlier, it is to make the Date readable -->
      <p><strong>Added:</strong> <%= song.createdAt.toLocaleString() %></p>

      <form action="/playlists/songs/delete" method="POST">
        <input type="hidden" name="playlistId" value="<%= playlist._id %>">
        <input type="hidden" name="songId" value="<%= song._id %>">
        <button type="submit">Delete Song</button>
      </form>
  <% } %>
<% } %>

</main>
</body>
</html>
