<!DOCTYPE html>
<html lang="en">
<head>
  <!-- Basic page settings -->
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>

  <!-- Simple page styles -->
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 0;
      background: #f4f4f4;
      color: #222;
    }

    header {
      background: #1db954;
      color: white;
      padding: 20px;
    }

    nav a {
      color: white;
      margin-right: 15px;
      text-decoration: none;
      font-weight: bold;
    }

    main {
      max-width: 900px;
      margin: 30px auto;
      background: white;
      padding: 25px;
      border-radius: 8px;
    }

    form {
      margin-top: 15px;
    }

    label {
      display: block;
      margin-top: 12px;
      font-weight: bold;
    }

    input,
    textarea {
      width: 100%;
      padding: 10px;
      margin-top: 6px;
      box-sizing: border-box;
    }

    button {
      margin-top: 15px;
      padding: 10px 16px;
      border: none;
      background: #1db954;
      color: white;
      cursor: pointer;
    }

    .error {
      color: #b00020;
      font-weight: bold;
    }

    .card {
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 16px;
      margin-bottom: 16px;
    }

    .inline-form {
      display: inline;
    }
  </style>
</head>
<body>
  <!-- Main page header -->
  <header>
    <h1>Mini Spotify Playlist Manager</h1>

    <!-- Main navigation -->
    <nav>
      <a href="/playlists">All Playlists</a>
      <a href="/playlists/add">Add Playlist</a>
    </nav>
  </header>

