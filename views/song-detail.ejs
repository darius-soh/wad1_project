<%- include("common/header", { title: title, user: user }) %>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Back link if song is missing -->
<% if (!song) { %>
  <p><a href="/songs">Back to songs</a></p>
<% } %>

<!-- Song details -->
<!-- This page shows one selected song and links back to related actions -->
<% if (song) { %>
  <form action="/songs/delete" method="POST">
    <input type="hidden" name="songId" value="<%= song._id %>">
    <button type="submit">Delete Song</button>
  </form>
  <br>

  <p><a href="/songs/edit?songId=<%= song._id %>">Edit Song</a></p>
  <p><a href="/reviews/add?songId=<%= song._id %>">Add Review</a></p>

  <h2><%= song.title %></h2>
  <p><strong>Artist:</strong> <%= song.artist %></p>
  <p><strong>Album:</strong> <%= song.album %></p>
  <p><strong>Genre:</strong> <%= song.genre %></p>
  <p><strong>Playlist:</strong> <a href="/playlists/view?id=<%= playlist._id %>"><%= playlist.name %></a></p>
  <p><strong>Created:</strong> <%= song.createdAt.toLocaleString() %></p>
<% } %>

</main>
</body>
</html>
