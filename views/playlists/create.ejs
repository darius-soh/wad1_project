<%- include("../partials/header") %>

<section>
  <h2>Create Playlist</h2>

  <% if (error) { %>
    <p><strong>Error:</strong> <%= error %></p>
  <% } %>

  <form action="/playlists" method="POST">
    <p>
      <label for="name">Playlist Name</label><br>
      <input id="name" name="name" type="text" value="<%= formData.name %>" required>
    </p>

    <p>
      <label for="description">Description</label><br>
      <textarea id="description" name="description" rows="4" cols="40" required><%= formData.description %></textarea>
    </p>

    <p>
      <label for="genre">Genre</label><br>
      <input id="genre" name="genre" type="text" value="<%= formData.genre %>" required>
    </p>

    <p>
      <button type="submit">Create Playlist</button>
    </p>
  </form>

  <p><a href="/playlists">Back to playlists</a></p>
</section>

<%- include("../partials/footer") %>
