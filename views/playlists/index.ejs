<%- include("../partials/header") %>

<section>
  <h2>All Playlists</h2>
  <p><a href="/playlists/new">Create a new playlist</a></p>

  <% if (!playlists.length) { %>
    <p>No playlists yet. Create the first playlist to get started.</p>
  <% } else { %>
    <ul>
      <% playlists.forEach((playlist) => { %>
        <li>
          <article>
            <h3>
              <a href="/playlists/<%= playlist.id %>"><%= playlist.name %></a>
            </h3>
            <p><strong>Description:</strong> <%= playlist.description %></p>
            <p><strong>Genre:</strong> <%= playlist.genre %></p>
            <p><strong>Creator:</strong> <%= playlist.createdByUsername %></p>
            <p><strong>Average Rating:</strong> <%= playlist.averageRatingText %></p>
          </article>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>

<%- include("../partials/footer") %>
