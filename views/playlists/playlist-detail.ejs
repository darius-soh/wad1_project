<%- include("../common/header", { title: title, user: user }) %>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Back link if playlist is missing -->
<% if (!playlist) { %>
  <p><a href="/playlists">Back to playlists</a></p>
<% } %>

<!-- Playlist details -->
<!-- This page shows one playlist together with all songs linked to it -->
<% if (playlist) { %>
  <table>
    <tr>
      <td style="width: 1000px;" colspan="2"><h2><%= playlist.name %></h2></td>
    </tr>
    <tr>
      <td><strong>Description:</strong></td>
      <td><%= playlist.description %></td>
    </tr>
    <tr>
      <td><strong>Created:</strong></td>
      <td><%= playlist.createdAt.toLocaleString() %></td>
    </tr>
    <tr>
      <td>
        <strong>Action:</strong>
      </td>
      <td>
        <form action="/playlists/edit" method="GET" style="display: inline-block;">
          <input type="hidden" name="playlistId" value="<%= playlist._id %>">
          <button type="submit" style="width: 90px;">Edit Playlist</button>
        </form>
        <form action="/playlists/delete" method="POST" style="display: inline-block;">
          <!-- We have to use the hidden variable so that when we process the post request, we are able to get the id  -->
          <!-- MongoDB automatically creates a field called _id for every document, so we will use that to get the unique ID of that document -->
          <input type="hidden" name="playlistId" value="<%= playlist._id %>">
          <button type="submit" onclick="return confirm('Are you sure you want to delete this?');">Delete Playlist</button>
        </form>      
        <form action="/songs/add" method="GET" style="display: inline-block;">
          <input type="hidden" name="playlistId" value="<%= playlist._id %>">
          <button type="submit" style="width: 100px;">Add Song</button>
        </form>
      </td>
    </tr>
  </table>

  <p> </p>

   <!-- Horizontal line separating playlist from songs -->
  <hr>
  
  <h3>Songs</h3>

  <!-- Search song (must be exact match) -->
  <form action="/playlists/view" method="GET">
    <input type="hidden" name="id" value="<%= playlist._id %>">
    <label for="search">Search for a song:</label>
    <input type="text" id="search" name="search" value="<%= searchTerm %>" placeholder="Search song title" style="width: 510px;">
    <button type="submit">Search</button>
  </form><br>  

  <!-- Message when there are no songs -->
  <% if (!songs || songs.length === 0) { %>
    <% if (searchTerm) { %>
      <p>No matching songs found.</p>
    <% } else { %>
      <p>No songs added yet.</p>
    <% } %>
  <% } %>


  <% if (songs && songs.length > 0) { %>      
    <% for (const song of songs) { %>
      <table border="1" style="width: 700px; max-width: 100%;">
        <tr>
          <th style="width: 140px; text-align: left;">Title</th>
          <td><%= song.title %></td>
        </tr>
        <tr>
          <th style="width: 140px; text-align: left;">Artist</th>
          <td><%= song.artist %></td>
        </tr>
        <tr>
          <th style="width: 140px; text-align: left;">Album</th>
          <td><%= song.album %></td>
        </tr>
        <tr>
          <th style="width: 140px; text-align: left;">Genre</th>
          <td><%= song.genre %></td>
        </tr>
        <tr>
          <th style="width: 140px; text-align: left;">Added</th>
          <td><%= song.createdAt.toLocaleString() %></td>
        </tr>
        <tr>
          <th style="width: 140px; text-align: left;">Action</th>
          <td>
            <form action="/songs/edit" method="GET" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit" style="width: 55px;">Edit</button>
            </form>
            <form action="/reviews/add" method="GET" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit">Review</button>
            </form>
            <form action="/liked-songs/add" method="GET" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit" style="width: 55px;">Like</button>
            </form>
            <form action="/songs/delete" method="POST" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit" onclick="return confirm('Are you sure you want to delete this?');">Delete</button>
            </form>
          </td>
        </tr>
      </table>
      <br>
    <% } %>
  <% } %>
<% } %>

</main>
</body>
</html>
