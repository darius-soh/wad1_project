<%- include("../common/header", { title: title, user: user }) %>

<!-- Page heading -->
<h2>Add Song</h2>

<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Back link if there are no playlists -->
<% if (!playlists || playlists.length === 0) { %>
  <p>No playlists found. <a href="/playlists/add">Create a playlist first</a></p>
<% } %>

<!-- Add song form -->
<!-- The playlist dropdown decides which playlist this new song should belong to -->
<% if (playlists && playlists.length > 0) { %>
  <form action="/songs/add" method="POST">
    <label for="playlistId">Playlist</label>
    <br>
    <select id="playlistId" name="playlistId">
      <option value="">--Select a Playlist--</option>

      <% for (const playlist of playlists) { %>
        <option value="<%= playlist._id %>" <%= formData.playlistId === String(playlist._id) ? "selected" : "" %>>
          <%= playlist.name %>
        </option>
      <% } %>
    </select>
    <br><br>

    <label for="title">Song Title</label>
    <br>
    <input id="title" name="title" type="text" value="<%= formData.title %>">
    <br><br>

    <label for="artist">Artist</label>
    <br>
    <input id="artist" name="artist" type="text" value="<%= formData.artist %>">
    <br><br>

    <label for="album">Album</label>
    <br>
    <input id="album" name="album" type="text" value="<%= formData.album %>">
    <br><br>

    <label for="genre">Song Genre</label>
    <br>
    <select id="genre" name="genre">
      <option value="">--Select a Genre--</option>

      <% if (genres && genres.length > 0) { %>
        <% for (const genre of genres) { %>
          <option value="<%= genre %>" <%= formData.genre === genre ? "selected" : "" %>>
            <%= genre %>
          </option>
        <% } %>
      <% } %>
    </select>
    <br><br>

    <button type="submit">Save Song</button>
  </form>
<% } %>

</main>
</body>
</html>
