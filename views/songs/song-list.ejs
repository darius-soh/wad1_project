<%- include("../common/header", { title: title, user: user }) %>

<!-- Page heading -->
<table width="100%">
  <tr>
    <td>
      <h2>All Songs</h2>
    </td>
  </tr>
  <tr>
    <td>
      <form action="/songs/add" method="GET">
        <button type="submit">Add a song</button>
      </form>
    </td>
  </tr>
</table>
<hr>

<form action="/songs" method="GET">

  <p><strong>Filter songs by genre</strong></p>
  <select id="genre" name="genre">
    <option value="">All Genres</option>

    <% if (genres && genres.length > 0) { %>
      <% for (const genre of genres) { %>
        <option value="<%= genre %>" <%= selectedGenre === genre ? "selected" : "" %>>
          <%= genre %>
        </option>
      <% } %>
    <% } %>
  </select>
  <button type="submit">Filter</button>
</form>
<br>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Message when there are no songs -->
<% if (!songs || songs.length === 0) { %>
  <p>No songs found.</p>
<% } %>

<!-- Songs table -->
<!-- Each song is displayed as its own small table -->
<% if (songs && songs.length > 0) { %>
  <% for (const song of songs) { %>
    <table width="50%" border="1">
      <tr>
        <td><strong>Title:</strong></td>
        <td><%= song.title %></td>
      </tr>
      <tr>
        <td><strong>Artist:</strong></td>
        <td><%= song.artist %></td>
      </tr>
      <tr>
        <td><strong>Album:</strong></td>
        <td><%= song.album %></td>
      </tr>
      <tr>
        <td><strong>Genre:</strong></td>
        <td><%= song.genre %></td>
      </tr>
      <tr>
        <td><strong>Playlist:</strong></td>
        <td><%= song.playlistName %></td>
      </tr>
      <tr>
        <td><strong>Action:</strong></td>
        <td>
            <form action="/songs/edit" method="GET" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit" style="width: 55px;">Edit</button>
            </form>
            <form action="/reviews/add" method="GET" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit">Review</button>
            </form>
            <form action="/liked-songs/add" method="GET" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit" style="width: 55px;">Like</button>
            </form>
            <form action="/songs/delete" method="POST" style="display: inline-block;">
              <input type="hidden" name="songId" value="<%= song._id %>">
              <button type="submit" onclick="return confirm('Are you sure you want to delete this?');">Delete</button>
            </form>
        </td>
      </tr>
    </table>
    <br>
    <hr>
    <br>
  <% } %>
<% } %>

</main>
</body>
</html>
