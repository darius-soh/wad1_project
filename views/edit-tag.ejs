<%- include("common/header", { title: title, user: user }) %>

<!-- Page heading -->
<h2>Edit Tag</h2>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Back link if there are no playlists -->
<% if (!playlists || playlists.length === 0) { %>
  <p>No playlists found. <a href="/playlists/add">Create a playlist first</a></p>
<% } %>

<!-- Edit tag form -->
<!-- The hidden tagId tells the controller which tag document to update -->
<% if (playlists && playlists.length > 0) { %>
  <form action="/tags/edit" method="POST">
    <input type="hidden" name="tagId" value="<%= formData.tagId %>">

    <label for="playlistId">Playlist</label>
    <br>
    <select id="playlistId" name="playlistId">
      <option value="">--Select a Playlist--</option>

      <% for (const playlist of playlists) { %>
        <option value="<%= playlist._id %>" <%= formData.playlistId === String(playlist._id) ? "selected" : "" %>>
          <%= playlist.name %>
        </option>
      <% } %>
    </select>
    <br><br>

    <label for="name">Tag Name</label>
    <br>
    <input id="name" name="name" type="text" value="<%= formData.name %>">
    <br><br>

    <label for="description">Description</label>
    <br>
    <textarea id="description" name="description" rows="4"><%= formData.description %></textarea>
    <br><br>

    <button type="submit">Save Changes</button>
  </form>
<% } %>

</main>
</body>
</html>
