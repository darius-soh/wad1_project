<%- include("../common/header", { title: title, user: user }) %>

<!-- Page heading -->
<h2>Add Liked Song</h2>

<!-- Error message -->
<% if (error) { %>
  <p><%= error %></p>
<% } %>

<!-- Back link if there are no songs -->
<% if (!songs || songs.length === 0) { %>
  <p>No songs found. <a href="/songs/add">Create a song first</a></p>
<% } %>

<!-- Add liked song form -->
<!-- The song dropdown decides which song this liked song entry should belong to -->
<% if (songs && songs.length > 0) { %>
  <form action="/liked-songs/add" method="POST">
    <label for="songId">Song</label>
    <br>
    <select id="songId" name="songId">
      <option value="">--Select a Song--</option>

      <% for (const song of songs) { %>
        <option value="<%= song._id %>" <%= formData.songId === String(song._id) ? "selected" : "" %>>
          <%= song.title %> (<%= song.playlistName %>)
        </option>
      <% } %>
    </select>
    <br><br>

    <label for="note">Why do you like this song?</label>
    <br>
    <textarea id="note" name="note" rows="4"><%= formData.note %></textarea>
    <br><br>

    <button type="submit">Save Liked Song</button>
  </form>
<% } %>

</main>
</body>
</html>
